# ── LogSphere Server — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values before starting the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Secret key used to sign and verify JWTs.
# Use a long, random string (e.g. openssl rand -hex 32).
JWT_SECRET=change_me_to_a_long_random_secret

# MongoDB connection URI.
# Default assumes a local MongoDB instance on the standard port.
MONGO_URI=mongodb://127.0.0.1:27017/logsphere

# Allowed CORS origin(s) for the dashboard.
# Use "*" for development or specify your dashboard URL for production.
# Example: CORS_ORIGIN=https://dashboard.yourdomain.com
CORS_ORIGIN=*

# Port the Express server listens on.
PORT=5000
